<Window x:Class="CateringIS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CateringIS.ViewModels"
        Height="780" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="/app.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── Sidebar ──────────────────────────────────────────────────── -->
        <DockPanel Grid.Column="0" Background="#2C3E50">
            <StackPanel DockPanel.Dock="Top" Margin="0,16,0,20">
                <TextBlock Text="🍽" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="ОбщепитИС" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="Система управления" FontSize="10" Foreground="#95A5A6"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,0">
                    <TextBlock Text="МЕНЮ" Foreground="#7F8C8D" FontSize="10" FontWeight="Bold"
                               Margin="4,8,0,4"/>
                    <Button Content="📋  Блюда (Меню)"       Command="{Binding NavProductsCommand}"    Style="{StaticResource NavBtn}"/>
                    <Button Content="🗂  Группы блюд"         Command="{Binding NavGroupsCommand}"      Style="{StaticResource NavBtn}"/>

                    <TextBlock Text="СКЛАД" Foreground="#7F8C8D" FontSize="10" FontWeight="Bold"
                               Margin="4,12,0,4"/>
                    <Button Content="🥦  Ингредиенты"         Command="{Binding NavIngredientsCommand}" Style="{StaticResource NavBtn}"/>
                    <Button Content="🚚  Приход товара"        Command="{Binding NavDeliveriesCommand}"  Style="{StaticResource NavBtn}"/>
                    <Button Content="📦  Заказы подразделений" Command="{Binding NavOrdersCommand}"      Style="{StaticResource NavBtn}"/>

                    <TextBlock Text="СПРАВОЧНИКИ" Foreground="#7F8C8D" FontSize="10" FontWeight="Bold"
                               Margin="4,12,0,4"/>
                    <Button Content="🏢  Поставщики"          Command="{Binding NavSuppliersCommand}"   Style="{StaticResource NavBtn}"/>
                    <Button Content="🏬  Подразделения"        Command="{Binding NavDepartmentsCommand}" Style="{StaticResource NavBtn}"/>

                    <TextBlock Text="АНАЛИТИКА" Foreground="#7F8C8D" FontSize="10" FontWeight="Bold"
                               Margin="4,12,0,4"/>
                    <Button Content="📊  Учёт продаж"          Command="{Binding NavSalesCommand}"       Style="{StaticResource NavBtn}"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- ─── Content Area ─────────────────────────────────────────────── -->
        <DockPanel Grid.Column="1" Background="#F4F6F8">
            <!-- Header bar -->
            <Border DockPanel.Dock="Top" Background="White"
                    BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="20,12">
                <TextBlock Text="{Binding CurrentTitle}"
                           FontSize="20" FontWeight="SemiBold" Foreground="#2C3E50"/>
            </Border>

            <!-- Routed content via DataTemplates -->
            <ContentPresenter Content="{Binding CurrentView}" Margin="0"/>
        </DockPanel>
    </Grid>
</Window>
