<UserControl x:Class="CateringIS.Views.IngredientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:CateringIS.Helpers">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- List -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Добавить"  Command="{Binding AddCommand}"    Style="{StaticResource ActionBtn}"/>
                <Button Content="🗑 Удалить"  Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"/>
                <Button Content="💾 Сохранить" Command="{Binding SaveCommand}"   Style="{StaticResource SecondaryBtn}"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Ingredients}" SelectedItem="{Binding Selected}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Наименование"  Binding="{Binding Name}"               Width="*"/>
                    <DataGridTextColumn Header="Ед. изм."      Binding="{Binding Unit}"               Width="80"/>
                    <DataGridTextColumn Header="Наценка %"     Binding="{Binding PriceMarkupPercent}" Width="80"/>
                    <DataGridTextColumn Header="Остаток"       Binding="{Binding StockBalance}"       Width="90"/>
                    <DataGridTextColumn Header="Поставщик"     Binding="{Binding Supplier.Name}"      Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Detail Panel -->
        <Border Grid.Column="1" Background="White" CornerRadius="6"
                BorderBrush="#DEE2E6" BorderThickness="1" Padding="16"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Редактирование продукта" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

                    <Label Content="Наименование"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.Name" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:NameValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Единица измерения"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.Unit" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:UnitValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Наценка (%)"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.PriceMarkupPercent" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:PercentValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Остаток на складе"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.StockBalance" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:PositiveNumberValidationRule AllowZero="True"/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Поставщик"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding Selected.Supplier}"
                              DisplayMemberPath="Name"
                              Padding="4,3" Margin="0,2"/>

                    <Button Content="💾 Сохранить" Click="SaveButton_Click"
                            Style="{StaticResource SecondaryBtn}" Margin="0,12,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
