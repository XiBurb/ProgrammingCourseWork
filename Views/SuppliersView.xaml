<UserControl x:Class="CateringIS.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:CateringIS.Helpers">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- List -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Добавить"  Command="{Binding AddCommand}"    Style="{StaticResource ActionBtn}"/>
                <Button Content="🗑 Удалить"  Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"/>
                <Button Content="💾 Сохранить" Command="{Binding SaveCommand}"   Style="{StaticResource SecondaryBtn}"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding Selected}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"          Binding="{Binding Name}"           Width="*"/>
                    <DataGridTextColumn Header="Адрес"             Binding="{Binding Address}"        Width="*"/>
                    <DataGridTextColumn Header="ИНН"               Binding="{Binding TaxId}"          Width="100"/>
                    <DataGridTextColumn Header="Менеджер"          Binding="{Binding ManagerFullName}" Width="140"/>
                    <DataGridTextColumn Header="Телефон"           Binding="{Binding ManagerPhone}"   Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Detail Panel -->
        <Border Grid.Column="1" Background="White" CornerRadius="6"
                BorderBrush="#DEE2E6" BorderThickness="1" Padding="16"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Редактирование поставщика" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

                    <Label Content="Название"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.Name" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:NameValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Адрес"/>
                    <TextBox TextWrapping="Wrap" MinLines="2" MaxLines="4" AcceptsReturn="True">
                        <TextBox.Text>
                            <Binding Path="Selected.Address" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:NameValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="ФИО менеджера"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.ManagerFullName" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:NameValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Телефон менеджера"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.ManagerPhone" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:PhoneValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Банк"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.BankName" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:NameValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Label Content="Расчётный счёт"/>
                    <TextBox Text="{Binding Selected.BankAccount, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="ИНН"/>
                    <TextBox>
                        <TextBox.Text>
                            <Binding Path="Selected.TaxId" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <helpers:TaxIdValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <Button Content="💾 Сохранить" Click="SaveButton_Click"
                            Style="{StaticResource SecondaryBtn}" Margin="0,12,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
