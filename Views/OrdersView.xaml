<UserControl x:Class="CateringIS.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="160"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*" MinHeight="200"/>
        </Grid.RowDefinitions>

        <!-- Orders list -->
        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Новый заказ" Command="{Binding AddCommand}"    Style="{StaticResource ActionBtn}"/>
                <Button Content="🗑 Удалить"     Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"/>
                <Button Content="💾 Сохранить"   Command="{Binding SaveCommand}"   Style="{StaticResource SecondaryBtn}"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding Selected}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№"              Binding="{Binding Id}"             Width="50"/>
                    <DataGridTextColumn Header="Дата"          Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Подразделение" Binding="{Binding Department.Name}" Width="*"/>
                    <DataGridTextColumn Header="Позиций"       Binding="{Binding Items.Count}"    Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="#DEE2E6"/>

        <!-- Order detail -->
        <Border Grid.Row="2" Background="White" CornerRadius="6"
                BorderBrush="#DEE2E6" BorderThickness="1" Padding="12"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Состав заказа" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Label Content="Дата:" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding Selected.OrderDate}" Width="130"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Подразделение:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Departments}" SelectedItem="{Binding Selected.Department}"
                                  DisplayMemberPath="Name" Width="180" Padding="4,3"/>
                    </StackPanel>
                    <Button Content="+ Строка" Command="{Binding AddItemCommand}"
                            Style="{StaticResource ActionBtn}" Margin="16,0,0,0"/>
                </WrapPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding OrderItems}" CanUserAddRows="False" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Ингредиент" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate><TextBlock Text="{Binding IngredientName}" Padding="4,2"/></DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.Ingredients,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedValue="{Binding IngredientId, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Id" DisplayMemberPath="Name"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Ед. изм."   Binding="{Binding Unit}"     Width="90"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTemplateColumn Header="" Width="30">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Background="Transparent" BorderThickness="0"
                                            Foreground="#E74C3C" FontWeight="Bold" Cursor="Hand"
                                            Command="{Binding DataContext.RemoveItemCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
